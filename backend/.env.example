# Comma-separated list of origins allowed to call the API.
# Example:
# BAJA_ALLOWED_ORIGINS=https://baja-demo.vercel.app,http://localhost:3000
BAJA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# YOLO weights to load. Defaults to the stock demo model.
BAJA_MODEL_WEIGHTS=yolov8n.pt

# Detection confidence threshold.
BAJA_CONF_THRESHOLD=0.25
