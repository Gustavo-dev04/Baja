# Copie para .env e preencha os valores reais.
# NUNCA commite o .env — ele já está no .gitignore.

# ── Supabase ──────────────────────────────────────────────
# Project URL  (ex: https://xyzxyz.supabase.co)
SUPABASE_URL=aclabwtsdzzdmpumtjbx

# Service Role Key  (Settings → API → service_role  — NUNCA exponha no frontend)
SUPABASE_SERVICE_ROLE_KEY=aclabwtsdzzdmpumtjbx

# Nomes dos buckets (padrão já configurado — só mude se renomear no Supabase)
SUPABASE_BUCKET_IMAGES=baja-images
SUPABASE_BUCKET_MODELS=baja-models

# ── Autenticação admin ────────────────────────────────────
# Senha para POST /api/v1/auth/admin-token
BAJA_ADMIN_PASSWORD=

# Secret para assinar JWT (string aleatória, 64+ caracteres)
BAJA_JWT_SECRET=

# ── Modelo YOLO ───────────────────────────────────────────
BAJA_MODEL_WEIGHTS=yolov8n.pt
BAJA_CONF_THRESHOLD=0.25

# ── CORS ─────────────────────────────────────────────────
# Domínio da Vercel (sem barra no final, separar vários por vírgula)
BAJA_ALLOWED_ORIGINS=http://localhost:3000

# ── Hugging Face (Semana 3+) ─────────────────────────────
# Token com permissão de write para upload do best.pt
HF_TOKEN=

# Repo de modelos (ex: gustavo-dev04/baja-models)
BAJA_HF_MODEL_REPO=
